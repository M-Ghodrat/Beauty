rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "mohsenghodrat2@gmail.com"
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\s]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidService(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'duration']) &&
             data.name is string && data.name.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             data.price is number && data.price >= 0 &&
             data.duration is number && data.duration > 0;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price']) &&
             data.name is string && data.name.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             data.price is number && data.price >= 0;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['serviceId', 'date', 'time', 'customerName', 'customerEmail']) &&
             isValidId(data.serviceId) &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.time is string && data.time.size() <= 10 &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.customerEmail is string && data.customerEmail.matches('^[^@]+@[^@]+\\.[^@]+$');
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.message is string && data.message.size() <= 2000 &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidService(incoming());
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(incoming());
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isValidAppointment(incoming()) && 
                    (!('userId' in incoming()) || incoming().userId == request.auth.uid) &&
                    exists(/databases/$(database)/documents/services/$(incoming().serviceId));
      allow update: if isAdmin() && (incoming().diff(existing()).affectedKeys().hasOnly(['status']));
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(incoming());
      allow read, list, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
